{
  "credentials": [
    {
      "id": "cred_openai",
      "name": "OpenAI API Key",
      "provider": "OPEN_AI",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer REPLACE_ME_OPENAI_API_KEY"
        }
      ]
    }
  ],
  "intents": [
    {
      "id": "intent_hello_world",
      "intent": "HELLO_WORLD",
      "type": "CHAT",
      "active": true,
      "inputSchema": {
        "name": { "type": "string", "required": true }
      },
      "outputSchema": {
        "result": { "type": "string", "required": true }
      },
      "defaultPrompt": {
        "id": "prompt_hello_world_v1",
        "name": "hello_world_v1",
        "version": "1.0",
        "variablesInterpolationType": "MUSTACHE",
        "params": {
          "response_format": "json_schema",
          "max_tokens": 128
        },
        "messages": [
          {
            "role": "system",
            "content": "Reply ONLY valid JSON with exactly one key: {\"result\":\"...\"}."
          },
          {
            "role": "user",
            "content": "Say hello to {{name}} in one short sentence."
          }
        ]
      },
      "retryPolicy": {
        "maxAttempts": 3,
        "maxPerCandidate": 2,
        "allowFallback": true,
        "retryOn": ["TIMEOUT", "UPSTREAM_5XX", "SCHEMA_FAIL"],
        "repairOnParseFail": true
      },
      "implementations": [
        {
          "id": "impl_openai_nano",
          "provider": "OPEN_AI",
          "name": "OpenAI (nano)",
          "version": "1.0",
          "model": "gpt-4.1-nano",
          "endpoint": "https://api.openai.com/v1",
          "active": true,
          "weight": 0.7,
          "credentialRef": "cred_openai"
        },
        {
          "id": "impl_openai_mini",
          "provider": "OPEN_AI",
          "name": "OpenAI (mini)",
          "version": "1.0",
          "model": "gpt-4.1-mini",
          "endpoint": "https://api.openai.com/v1",
          "active": true,
          "weight": 0.3,
          "credentialRef": "cred_openai"
        }
      ]
    }
  ]
}
